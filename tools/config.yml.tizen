# 指定测试项目，分IPTV和OTT
project: OTT

device:
  # 测试设备和包名，用于通过adb获取信息
  id: MAX0019111000244
  package: com.mgtv.tv
#  id: 192.168.202.125:5555
#  package: com.hunantv.operator

# url中显示上报类型
display: on
# 显示原始数据
primitive: off
# 字段缺失校验
lack: on
# 接口请求参数排序
sort: on
# 不校验字符类型
not_int: on

OTT:
  common:
    # 公共字段
    time: time_compare-14
    sessionid: empty_compare
    did: '244B0303C4F9'
#    newdid: len_compare-36
    uuid: inter_compare
    net: '1'
    isdebug: '0'
    mf: 'SAMSUNG'
    mod: '15_HAWKM_UHD'
